# Database (Postgres — see DEPLOYMENT.md for how to provision one on Render)
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# Public site URL (no trailing slash) — drives metadataBase, canonical URLs,
# the sitemap, and robots.txt. Set to the real subdomain once it's live.
NEXT_PUBLIC_SITE_URL="https://pcp.ftcinternational.com"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-long-random-string"

# Allow free (no-Stripe) unlock of plans on a deployed server. Intended for
# testing/pre-launch before real payments are turned on. Set to "true" to
# enable, remove or set to anything else to disable. Ignored (always off)
# once STRIPE_SECRET_KEY is set.
ALLOW_FREE_UNLOCK="true"

# Stripe (billing) — leave blank to run in "billing disabled" dev mode
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_ID_ONE_TIME=""
STRIPE_PRICE_ID_STORAGE_SUBSCRIPTION=""

# Data retention default (days) for accounts on the free/one-time tier before
# plan data is purged unless the user has an active storage subscription.
DEFAULT_RETENTION_DAYS="90"
